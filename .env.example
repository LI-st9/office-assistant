# ============================================================
# 智能办公助手项目 - 环境变量配置
# ============================================================
# 
# 使用方法:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填入你的 API Key
# 3. 运行示例代码
#
# ============================================================

# 例如通义千问 API Key（必填）
DASHSCOPE_API_KEY=your-api-key-here

# 服务配置
HOST=127.0.0.1
PORT=7860

# 是否开启公网分享
SHARE=False